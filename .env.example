# NightWatch environment variables (renderer-safe values only).
# Copy to .env and fill in. NEVER put the Supabase service role or
# secret key here — only the anon (public) key is ever embedded.
# Not used until Phase 3 (room system / Supabase Realtime).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Discord Application Client ID (public) — enables Rich Presence.
VITE_DISCORD_CLIENT_ID=

# ---------------------------------------------------------------------------
# Phase 29 authorized media (Electron main process; read at runtime, loaded
# from .env in dev by electron/main.ts). A desktop OAuth client's id/secret
# and a Picker-restricted API key ship in the binary and are not server
# secrets — but they still belong in .env, not in git.
# ---------------------------------------------------------------------------

# Desktop-app OAuth client (Google Cloud Console → Credentials).
NIGHTWATCH_GOOGLE_CLIENT_ID=
NIGHTWATCH_GOOGLE_CLIENT_SECRET=
# API key restricted to the Google Picker API.
NIGHTWATCH_GOOGLE_PICKER_API_KEY=
# The Google Cloud PROJECT NUMBER (not the project id).
NIGHTWATCH_GOOGLE_APP_ID=

# Capability switches. Leave unset in release builds until packaged
# acceptance passes (PHASE_29_MEDIA_LIBRARY_HANDOFF.md).
NIGHTWATCH_ENABLE_LOCAL_FILES=
NIGHTWATCH_ENABLE_DRIVE=
NIGHTWATCH_ENABLE_LIBRARY=
