# NightWatch environment variables (renderer-safe values only).
# Copy to .env and fill in. NEVER put the Supabase service role or
# secret key here — only the anon (public) key is ever embedded.
# Not used until Phase 3 (room system / Supabase Realtime).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
