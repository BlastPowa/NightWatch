# NightWatch environment variables (renderer-safe values only).
# Copy to .env and fill in. NEVER put the Supabase service role or
# secret key here — only the anon (public) key is ever embedded.
# Not used until Phase 3 (room system / Supabase Realtime).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Discord Application Client ID (public) — enables Rich Presence.
VITE_DISCORD_CLIENT_ID=

# Phase 29 authorized media (Electron only).
# These are public desktop-application configuration values, not OAuth tokens.
# Use exact 1/0 flags. Leave disabled until packaged acceptance is complete.
NIGHTWATCH_ENABLE_LOCAL_FILES=0
NIGHTWATCH_ENABLE_DRIVE=0
NIGHTWATCH_ENABLE_LIBRARY=0
NIGHTWATCH_MAX_MEDIA_BYTES=34359738368

# Google Desktop OAuth + Picker configuration.
# The identifiers and Picker key are public desktop-app configuration; restrict
# the Picker key to the Google Picker API. Never place access or refresh tokens
# in this file.
NIGHTWATCH_GOOGLE_CLIENT_ID=
NIGHTWATCH_GOOGLE_PICKER_API_KEY=
NIGHTWATCH_GOOGLE_APP_ID=

# Optional read-only YouTube account connection. This uses a separate consent
# grant and separate encrypted credential file from Google Drive.
NIGHTWATCH_ENABLE_YOUTUBE_ACCOUNT=0

# Do not put Google refresh/access tokens here. Desktop OAuth tokens are stored
# locally through Electron safeStorage.
